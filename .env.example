# ===========================================
# Aplicação
# ===========================================
APP_NAME="Atlas"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=America/Sao_Paulo
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR

# ===========================================
# Porta exposta pelo Nginx
# ===========================================
APP_PORT=8000

# ===========================================
# UID/GID do seu usuário (Linux/Mac)
# Em Windows, deixe 1000:1000
# Para descobrir no Linux: id -u && id -g
# ===========================================
UID=1000
GID=1000

# ===========================================
# Banco de Dados PostgreSQL
# ===========================================
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=atlas
DB_USERNAME=atlas_user
# TROCAR ESTA SENHA em qualquer ambiente que não seja localhost
DB_PASSWORD=dev_password_change_me

# ===========================================
# Redis (cache, sessões, filas)
# ===========================================
REDIS_HOST=redis
REDIS_PORT=6379
# TROCAR ESTA SENHA em qualquer ambiente que não seja localhost
REDIS_PASSWORD=dev_redis_change_me
REDIS_CLIENT=phpredis

# ===========================================
# Cache e Sessão
# ===========================================
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=false  # true em produção (HTTPS)
SESSION_SAME_SITE=lax
QUEUE_CONNECTION=redis

# ===========================================
# Email (Mailpit em dev — captura todos os envios)
# Em produção, configurar SMTP real
# ===========================================
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="sistema@atlas.local"
MAIL_FROM_NAME="${APP_NAME}"

# Porta da UI do Mailpit (acesse http://localhost:8025)
MAIL_UI_PORT=8025

# ===========================================
# Logs
# ===========================================
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ===========================================
# Configurações de Segurança
# ===========================================
# Tentativas de login antes de bloqueio temporário
LOGIN_MAX_ATTEMPTS=5
LOGIN_DECAY_MINUTES=1

# Tempo de expiração de tokens de recuperação de senha (minutos)
PASSWORD_RESET_TIMEOUT=60

# Forçar verificação de email no cadastro
REQUIRE_EMAIL_VERIFICATION=true

# ===========================================
# Filesystem
# ===========================================
FILESYSTEM_DISK=local

# ===========================================
# Vite (build de assets)
# ===========================================
VITE_APP_NAME="${APP_NAME}"
