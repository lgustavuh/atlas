# ===================================================================
#  Atlas - Variaveis de ambiente para Railway
#
#  COMO USAR:
#    1. No painel do Railway, abra o projeto -> Variables
#    2. Copie estas variaveis (ou cole via 'RAW Editor')
#    3. Substitua os valores marcados como ALTERAR
#    4. DATABASE_URL vem do Supabase - veja DEPLOY.md
# ===================================================================

# --- App ---
APP_NAME=Atlas
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=America/Sao_Paulo
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR
APP_URL=https://__SUBSTITUIR_PELO_DOMINIO_DO_RAILWAY__

# ALTERAR: gere uma chave nova com `php artisan key:generate --show`
# ou use qualquer string base64 de 32 bytes precedida de "base64:"
APP_KEY=

# --- Banco (Supabase) ---
# ALTERAR: copie a connection string do Supabase (Project Settings -> Database)
# Use o "Connection pooling" (porta 6543), modo Transaction
DB_CONNECTION=pgsql
DB_HOST=aws-0-us-east-2.pooler.supabase.com
DB_PORT=6543
DB_DATABASE=postgres
DB_USERNAME=postgres.__PROJECT_REF__
DB_PASSWORD=__SENHA_DO_SUPABASE__
DB_CHARSET=utf8

# Pooler do Supabase nao mantem prepared statements entre requests
DB_PREPARES=false

# --- Cache, sessao, filas (sem Redis: usa banco + arquivos) ---
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
QUEUE_CONNECTION=sync

# --- Logs (sempre stdout em container) ---
LOG_CHANNEL=stderr
LOG_LEVEL=info

# --- Filesystem (efemero em Railway free tier) ---
FILESYSTEM_DISK=local

# --- Migrations: roda no boot do container ---
DB_RUN_MIGRATIONS=true

# --- Seed inicial (admin + perfis + geografia). Setar TRUE so na PRIMEIRA vez ---
SEED_DATABASE=false

# --- Email (sem SMTP configurado: usa "log" - emails ficam no stderr) ---
MAIL_MAILER=log
MAIL_FROM_ADDRESS=sistema@atlas.app
MAIL_FROM_NAME=Atlas

# --- Seguranca ---
LOGIN_MAX_ATTEMPTS=5
LOGIN_DECAY_MINUTES=1
PASSWORD_RESET_TIMEOUT=60
REQUIRE_EMAIL_VERIFICATION=false
